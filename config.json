{
  "IGNORE": ["www.google.com:80", "aws-0-eu-west-1.pooler.supabase.com:5432"],
  "backends": [
    {
      "address": "http://localhost:3000",
      "maxConnections": 100000000
    },
    {
      "address": "http://localhost:3001",
      "maxConnections": 100000000
    }
  ],
  "balanceMode": "roundRobin",

  "maxConnections": 120000,

  "maxConcurrentConnectionsPerIP": 70000,

  "connectionRateLimitPerMinute": 1000000,

  "idleTimeoutMs": 5000,

  "dnsRefreshIntervalMs": 15000,

  "tls": "passthrough",

  "proxyProtocol": {
    "enabled": false,
    "version": 2
  },

  "healthCheck": {
    "intervalMs": 5000,
    "failureThreshold": 3,
    "successThreshold": 1
  },
  "debug": false
}
